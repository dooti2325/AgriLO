# Agri-Lo Environment Variables Template
# Copy this file to server/.env and client/.env (assigning relevant variables)

# === Server Settings ===
# Database
DATABASE_URL=sqlite+aiosqlite:///./farming.db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Payments
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder

# MQTT Hardware
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=farm/soil/node01/data

# App Settings
APP_NAME=Agri-Lo API
APP_VERSION=1.0.0
DEBUG=True

# CORS (comma-separated origins for production)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# === Client Settings ===
VITE_API_BASE_URL=http://localhost:8000
